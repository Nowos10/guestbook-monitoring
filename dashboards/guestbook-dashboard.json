{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "title": "Guestbook — Application Monitoring",
  "uid": "guestbook-monitoring",
  "tags": ["guestbook", "4ir-exercise"],
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-30m", "to": "now" },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "label": "Data source",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0,
        "refresh": 1
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Frontend (black-box probe + pod resources)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "Frontend availability (probe_success)",
      "id": 2,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" } } },
            { "type": "value", "options": { "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null }, { "color": "green", "value": 1 }
          ] },
          "min": 0, "max": 1
        }
      },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "min(probe_success{job=\"guestbook-frontend-blackbox\"})" }
      ]
    },
    {
      "type": "stat",
      "title": "Frontend HTTP status code",
      "id": 3,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 1 },
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "max(probe_http_status_code{job=\"guestbook-frontend-blackbox\"})" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Frontend probe latency",
      "id": 4,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "probe_duration_seconds{job=\"guestbook-frontend-blackbox\"}",
          "legendFormat": "total probe time" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(probe_http_duration_seconds{job=\"guestbook-frontend-blackbox\"})",
          "legendFormat": "http duration" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Frontend pod CPU (cores)",
      "id": 5,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 7 },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (pod) (rate(container_cpu_usage_seconds_total{namespace=\"guestbook\", pod=~\"frontend.*\", container!=\"\"}[5m]))",
          "legendFormat": "{{pod}}" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Frontend pod memory (working set)",
      "id": 6,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 7 },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (pod) (container_memory_working_set_bytes{namespace=\"guestbook\", pod=~\"frontend.*\", container!=\"\"})",
          "legendFormat": "{{pod}}" }
      ]
    },
    {
      "type": "row",
      "title": "Backend — Redis (redis_exporter)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 7,
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Redis commands processed / sec (request rate)",
      "id": 8,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 15 },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (pod) (rate(redis_commands_processed_total{namespace=\"guestbook\"}[5m]))",
          "legendFormat": "{{pod}}" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Redis connected clients",
      "id": 9,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 15 },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "redis_connected_clients{namespace=\"guestbook\"}",
          "legendFormat": "{{pod}}" }
      ]
    },
    {
      "type": "stat",
      "title": "Redis keys (guestbook entries)",
      "id": 10,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 22 },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(redis_db_keys{namespace=\"guestbook\"})" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Redis memory used",
      "id": 11,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 6, "w": 18, "x": 6, "y": 22 },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "redis_memory_used_bytes{namespace=\"guestbook\"}",
          "legendFormat": "{{pod}}" }
      ]
    }
  ]
}
